{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Start Backend API",
			"type": "shell",
			"command": "cd budgetwise-app/backend && dotnet run",
			"group": "build",
			"isBackground": true,
			"problemMatcher": [
				"$msCompile"
			],
			"runOptions": {
				"runOn": "folderOpen"
			}
		},
		{
			"label": "Start Frontend Dev Server",
			"type": "shell",
			"command": "cd budgetwise-app/frontend && npm run dev",
			"group": "build",
			"isBackground": true,
			"problemMatcher": [],
			"runOptions": {
				"runOn": "folderOpen"
			}
		},
		{
			"label": "Start Full Application",
			"dependsOn": [
				"Start Backend API",
				"Start Frontend Dev Server"
			],
			"group": "build",
			"problemMatcher": []
		}
	]
}
